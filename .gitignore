# ==============================================================================
# HywelStar Video Player - Git Ignore Patterns
# ==============================================================================

# ------------------------------------------------------------------------------
# IDEs & Editors
# ------------------------------------------------------------------------------
.idea/
.qtcreator/
.vs/
.vscode/
.settings/

# Editor temp/backup files
*.swp
*.swo
*~
*.autosave
tags

# ------------------------------------------------------------------------------
# Build System & CMake
# ------------------------------------------------------------------------------
build*/
cmake-build-*/
out/
CMakeFiles/
CMakeCache.txt
CMakeLists.txt.user*
CMakeUserPresets.json
compile_commands.json
cmake_install.cmake
Makefile
*.ninja
.ninja_log
build.ninja

# ------------------------------------------------------------------------------
# Qt Generated Files
# ------------------------------------------------------------------------------
*_qmlcache.qrc
qrc_*.cpp
moc_*.cpp
moc_*.h
ui_*.h
*.moc
*.prl
*.qm

# ------------------------------------------------------------------------------
# Compiled Objects & Binaries
# ------------------------------------------------------------------------------
*.o
*.obj
*.exe
*.dll
*.so
*.so.*
*.dylib
*.a
*.lib
*.pdb
*.ilk
*.exp
*.idb

# Build output directories
Debug/
Release/
x64/
x86/

# Packaging & distribution
*.dmg
*.deb
*.rpm
*.AppImage
*.apk
*.aab

# ------------------------------------------------------------------------------
# Platform-Specific
# ------------------------------------------------------------------------------

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows - Visual Studio
*.vcproj
*.vcxproj*
*.sln
*.suo
*.ncb
*.sdf
*.ipch
*.opensdf

# ------------------------------------------------------------------------------
# Android Build
# ------------------------------------------------------------------------------
android/build/
android/.gradle/
.gradle/
local.properties
*.keystore
!debug.keystore

# ------------------------------------------------------------------------------
# Runtime & Logs
# ------------------------------------------------------------------------------
*.log
*.tmp
*.temp
*.bak
*.orig

# ------------------------------------------------------------------------------
# Deployment (generated at runtime)
# ------------------------------------------------------------------------------
lib/gstreamer-1.0/
plugins/
translations/

# ------------------------------------------------------------------------------
# OS Generated
# ------------------------------------------------------------------------------
Thumbs.db
desktop.ini
ehthumbs.db
.Spotlight-V100
.Trashes
env.local.bat
dist/


